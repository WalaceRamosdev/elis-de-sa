---
const navItems = [
  { name: 'Início', href: '/' },
  { name: 'Sobre', href: '/sobre' },
  { name: 'Serviços', href: '/servicos' },
  { name: 'Galeria', href: '/galeria' },
  { name: 'Contato', href: '/contato' },
];
---

<header class="header" id="main-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/images/logo/logo.svg" alt="Elis de Sá - Enfermeira" class="logo-img" />
    </a>
    
    <nav class="nav">
      <ul class="nav-links">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="nav-item">
              <span class="nav-text">{item.name}</span>
              <span class="nav-dot"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
    
    <div class="header-actions">
      <a href="https://wa.me/5511986214894" class="cta-pill" target="_blank">
        <span class="cta-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.437 5.711 1.438h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
          </svg>
        </span>
        <span class="cta-text">Agendar</span>
      </a>
      
      <button class="burger" id="burger-menu" aria-label="Menu">
        <span class="burger-line line-1"></span>
        <span class="burger-line line-2"></span>
      </button>
    </div>
  </div>
  
  <div class="drawer" id="mobile-drawer">
    <button class="close-drawer" id="close-drawer" aria-label="Fechar menu">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
    <div class="drawer-content">
      <ul class="drawer-links">
        {navItems.map((item, index) => (
          <li style={`--i: ${index}`}>
            <a href={item.href} class="drawer-item">{item.name}</a>
          </li>
        ))}
      </ul>
      <div class="drawer-footer">
        <p>Cuidados humanizados em Suzano</p>
        <a href="https://wa.me/5511986214894" class="btn btn-primary w-full">Falar com Elis</a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 20px 20px;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    justify-content: center;
  }

  .header.scrolled {
    padding: 10px 20px;
  }

  .header-inner {
    width: 100%;
    max-width: 1200px;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 100px;
    padding: 12px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .header.scrolled .header-inner {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 10px 40px rgba(88, 47, 14, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.6);
    max-width: 950px;
    padding: 8px 12px 8px 24px;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: var(--dark-brown);
    padding: 8px;
    border-radius: 50%;
    box-shadow: 0 4px 15px rgba(88, 47, 14, 0.15);
    z-index: 1001;
  }

  .logo:hover {
    transform: scale(1.1);
    background: var(--primary);
  }

  .logo-img {
    height: 30px;
    width: auto;
    transition: all 0.6s ease;
    filter: brightness(0) invert(1); 
  }

  .header.scrolled .logo {
    padding: 6px;
  }

  .header.scrolled .logo-img {
    height: 24px;
  }

  .nav {
    display: flex;
    align-items: center;
  }

  .nav-links {
    display: flex;
    gap: 8px;
    list-style: none;
  }

  .nav-item {
    position: relative;
    padding: 8px 16px;
    color: var(--text-dark);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 50px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .nav-item:hover {
    background: rgba(212, 163, 115, 0.1);
    color: var(--primary);
  }

  .nav-dot {
    width: 4px;
    height: 4px;
    background: var(--primary);
    border-radius: 50%;
    margin-top: 2px;
    opacity: 0;
    transform: scale(0);
    transition: all 0.3s ease;
  }

  .nav-item:hover .nav-dot {
    opacity: 1;
    transform: scale(1);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cta-pill {
    background: var(--dark-brown);
    color: white;
    padding: 8px 20px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 12px rgba(88, 47, 14, 0.2);
  }

  .cta-pill:hover {
    transform: translateY(-2px);
    background: var(--primary);
    box-shadow: 0 8px 20px rgba(212, 163, 115, 0.3);
  }

  .cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .burger {
    width: 38px;
    height: 38px;
    background: rgba(88, 47, 14, 0.05);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    transition: all 0.3s ease;
    z-index: 1001;
  }

  .header.scrolled .burger {
    background: rgba(88, 47, 14, 0.08);
  }

  .burger-line {
    width: 18px;
    height: 1.5px;
    background: var(--dark-brown);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Drawer Design */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 0;
    background: linear-gradient(135deg, #fffaf7 0%, var(--rose) 100%);
    overflow: hidden;
    transition: width 0.6s cubic-bezier(0.7, 0, 0.3, 1);
    z-index: 999;
  }

  .drawer.active {
    width: 100%;
  }

  .drawer-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .drawer.active .drawer-content {
    opacity: 1;
    transition-delay: 0.4s;
  }

  .drawer-links {
    list-style: none;
    text-align: center;
    margin-bottom: 40px;
  }

  .drawer-item {
    font-size: 2rem;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: var(--dark-brown);
    margin: 10px 0;
    display: block;
    opacity: 0;
    transform: translateY(15px);
    transition: all 0.5s ease;
    letter-spacing: -0.5px;
  }

  .drawer.active .drawer-item {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(0.1s * var(--i) + 0.4s);
  }

  .drawer-footer {
    text-align: center;
    color: var(--text-light);
  }

  /* Interaction Scripts Styles */
  .burger.active .line-1 { transform: translateY(3.5px) rotate(45deg); }
  .burger.active .line-2 { transform: translateY(-3.5px) rotate(-45deg); }

  @media (max-width: 992px) {
    .nav { display: none; }
    .burger { display: flex; }
    .cta-pill { display: none; }
    .header.scrolled .header-inner {
      max-width: 92%;
    }
    .header-inner {
      padding: 12px 20px;
    }
  }

  @media (max-width: 480px) {
    .header-inner { 
      padding: 10px 16px; 
      border-radius: 50px;
    }
    .drawer-item { font-size: 1.8rem; }
  }

  .close-drawer {
    position: absolute;
    top: 25px;
    right: 25px;
    background: rgba(88, 47, 14, 0.05);
    border: none;
    border-radius: 50%;
    color: var(--dark-brown);
    cursor: pointer;
    padding: 12px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .close-drawer:hover {
    background: rgba(88, 47, 14, 0.1);
    transform: rotate(90deg);
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const burger = document.getElementById('burger-menu');
  const drawer = document.getElementById('mobile-drawer');
  
  // Scroll Logic
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  const closeBtn = document.getElementById('close-drawer');

  function toggleMenu() {
    burger?.classList.toggle('active');
    drawer?.classList.toggle('active');
    
    if (drawer?.classList.contains('active')) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'auto';
    }
  }

  // Burger Interaction
  burger?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);

  // Close drawer on link click
  const drawerLinks = document.querySelectorAll('.drawer-item');
  drawerLinks.forEach(link => {
    link.addEventListener('click', () => {
      burger?.classList.remove('active');
      drawer?.classList.remove('active');
      document.body.style.overflow = 'auto';
    });
  });
</script>
