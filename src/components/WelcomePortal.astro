<div id="welcome-portal" class="welcome-portal">
  <div class="portal-side left"></div>
  <div class="portal-side right"></div>
  
  <div class="portal-content" id="portal-content">
    <div class="logo-badge">
      <img src="/images/logo/logo.svg" alt="Elis de Sá" class="portal-logo" />
    </div>
    <h1 class="portal-title">Bem-vinda</h1>
    <p class="portal-subtitle">Cuidados humanizados de enfermaria para você e sua família.</p>
    
    <button id="enter-site" class="enter-btn">
      <span class="btn-text">Entrar no Site</span>
      <span class="btn-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </span>
    </button>
  </div>
</div>

<style>
  .welcome-portal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    transition: visibility 1s;
  }

  .portal-side {
    position: absolute;
    top: 0;
    width: 50%;
    height: 100%;
    background: rgba(255, 250, 247, 0.7);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .portal-side.left {
    left: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.3);
  }

  .portal-side.right {
    right: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
  }

  .portal-content {
    position: relative;
    z-index: 10001;
    text-align: center;
    padding: 2rem;
    transition: all 0.8s ease;
  }

  .logo-badge {
    background: var(--dark-brown);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
    box-shadow: 0 15px 35px rgba(88, 47, 14, 0.2);
    animation: pulse 2s infinite ease-in-out;
  }

  .portal-logo {
    width: 70px;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .portal-title {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    color: var(--dark-brown);
    margin-bottom: 15px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInSlide 1s forwards 0.5s;
  }

  .portal-subtitle {
    color: var(--text-light);
    font-size: 1.1rem;
    max-width: 400px;
    margin: 0 auto 40px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInSlide 1s forwards 0.8s;
  }

  .enter-btn {
    background: var(--dark-brown);
    color: white;
    border: none;
    padding: 16px 40px;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 15px;
    margin: 0 auto;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInSlide 1s forwards 1.1s;
    box-shadow: 0 10px 25px rgba(88, 47, 14, 0.15);
  }

  .enter-btn:hover {
    background: var(--primary);
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 15px 35px rgba(212, 163, 115, 0.3);
  }

  .enter-btn:hover .btn-icon {
    transform: translateX(5px);
  }

  .btn-icon {
    transition: transform 0.3s ease;
  }

  /* Portal Animation Classes */
  .welcome-portal.open .portal-side.left {
    transform: translateX(-100%);
  }
  .welcome-portal.open .portal-side.right {
    transform: translateX(100%);
  }
  .welcome-portal.open .portal-content {
    opacity: 0;
    transform: scale(0.9);
    pointer-events: none;
  }
  .welcome-portal.open {
    visibility: hidden;
    pointer-events: none;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 15px 35px rgba(88, 47, 14, 0.2); }
    50% { transform: scale(1.05); box-shadow: 0 20px 45px rgba(88, 47, 14, 0.3); }
  }

  @keyframes fadeInSlide {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .portal-title { font-size: 2.5rem; }
    .portal-subtitle { font-size: 1rem; padding: 0 20px; }
  }
</style>

<script>
  const portal = document.getElementById('welcome-portal');
  const enterBtn = document.getElementById('enter-site');

  function openPortal() {
    portal?.classList.add('open');
    document.body.style.overflow = 'auto';
    // Save that user has seen the portal in this session
    sessionStorage.setItem('portalSeen', 'true');
  }

  // Check if portal should be shown
  if (sessionStorage.getItem('portalSeen')) {
    portal?.classList.add('open');
    portal!.style.display = 'none';
  } else {
    document.body.style.overflow = 'hidden';
  }

  enterBtn?.addEventListener('click', openPortal);
</script>
