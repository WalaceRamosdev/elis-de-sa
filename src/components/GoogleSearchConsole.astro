---
// Google Search Console Site Verification
// Replace 'YOUR_VERIFICATION_CODE' with the code from Search Console
const GSC_ID = import.meta.env.PUBLIC_GSC_ID || 'YOUR_VERIFICATION_CODE';
---

{GSC_ID !== 'YOUR_VERIFICATION_CODE' && (
  <meta name="google-site-verification" content={GSC_ID} />
)}
