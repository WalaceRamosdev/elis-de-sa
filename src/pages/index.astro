---
import Layout from '../layouts/Layout.astro';

const technicalServices = [
  { title: "Banho no leito", price: "R$ 80" },
  { title: "Banho em RN", price: "R$ 35" },
  { title: "Sondagem vesical de demora", price: "R$ 160" },
  { title: "Sondagem vesical de alívio", price: "R$ 110" },
  { title: "Antibióticoterapia", price: "R$ 80" },
  { title: "Troca de bolsa de colostomia/ileostomia", price: "R$ 70" },
  { title: "Limpeza de cânula endotraqueal", price: "R$ 70" },
  { title: "Curativos infectados", price: "R$ 70" },
  { title: "Curativos limpos", price: "R$ 40" },
  { title: "Retirada de pontos", price: "R$ 45" },
  { title: "Aspiração traqueal e vias aéreas superiores", price: "R$ 45" },
  { title: "Aplicação de medicação", price: "R$ 25" }
];
---

<Layout title="Início">
  <!-- Hero Section -->
  <section class="hero fade-in">
    <div class="container hero-container">
      <div class="hero-content">
        <span class="badge">Especialista em Enfermagem Obstétrica Domiciliar</span>
        <h1>Entre a técnica e a entrega, existe <span>amor</span>.</h1>
        <p>Cuidados humanizados e especializados para gestantes, puérperas e recém-nascidos no conforto do seu lar em Suzano.</p>
        <div class="hero-actions">
          <a href="https://wa.me/5511986214894" class="btn btn-whatsapp">Agendar pelo WhatsApp</a>
          <a href="/servicos" class="btn btn-outline">Conhecer Serviços</a>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-wrapper">
          <!-- Substitua por: /images/profissional/elis-hero.webp -->
          <img src="images/profissional/elis-hero-clean1.webp" alt="Elis de Sá - Enfermeira" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Section -->
  <section class="authority section">
    <div class="container">
      <div class="authority-grid">
        <div class="authority-card">
          <div class="icon">🏥</div>
          <h3>6+ Anos de Experiência</h3>
          <p>Atuação no Hospital das Clínicas de São Paulo, referência em saúde.</p>
        </div>
        <div class="authority-card">
          <div class="icon">🎓</div>
          <h3>Especialista Einstein</h3>
          <p>Pós-graduada em Enfermagem Obstétrica e Ginecológica pela Faculdade Albert Einstein.</p>
        </div>
        <div class="authority-card">
          <div class="icon">❤️</div>
          <h3>Cuidado Humanizado</h3>
          <p>Foco na conexão emocional e segurança da mãe e do bebê.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Services -->
  <section class="services section bg-light">
    <div class="container">
      <h2 class="text-center">Serviços em Destaque</h2>
      <p class="text-center section-subtitle">Cuidado especializado onde você mais se sente segura.</p>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-image">
            <img src="/images/servicos/servico_ausculta_bcf.webp" alt="Ausculta de BCF" loading="lazy" />
          </div>
          <div class="service-info">
            <h3>Ausculta de BCF</h3>
            <p>Ouça o coração do seu bebê no conforto do seu lar com segurança técnica.</p>
            <span class="price">R$ 55</span>
            <a href="/servicos" class="btn-text">Saiba mais →</a>
          </div>
        </div>
        
        <div class="service-card highlight">
          <div class="service-image">
            <img src="/images/servicos/servico_taping_gestacional.webp" alt="Taping Terapêutico" loading="lazy" />
          </div>
          <div class="service-info">
            <h3>Taping Terapêutico</h3>
            <p>Alívio imediato para desconfortos da gestação e auxílio na recuperação pós-parto.</p>
            <span class="price">R$ 200</span>
            <a href="/servicos" class="btn-text">Saiba mais →</a>
          </div>
        </div>
        
        <div class="service-card">
          <div class="service-image">
            <img src="/images/servicos/servico_sinais_vitais.webp" alt="Sinais Vitais" loading="lazy" />
          </div>
          <div class="service-info">
            <h3>Monitoramento</h3>
            <p>Aferição de sinais vitais e acompanhamento clínico rigoroso para sua tranquilidade.</p>
            <span class="price">R$ 25</span>
            <a href="/servicos" class="btn-text">Saiba mais →</a>
          </div>
        </div>
      </div>
      
      <!-- Additional Technical Procedures Dropdown -->
      <div class="home-procedures">
        <div class="accordion">
          <details>
            <summary>
              <span>Ver outros procedimentos técnicos e valores</span>
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="accordion-content">
              <div class="procedures-grid">
                {technicalServices.map(service => (
                  <div class="procedure-item">
                    <span class="procedure-title">{service.title}</span>
                    <span class="procedure-divider"></span>
                    <span class="procedure-price">{service.price}</span>
                    <a href={`https://wa.me/5511986214894?text=Olá%20Elis!%20Tenho%20interesse%20no%20procedimento:%20${service.title}`} class="procedure-link" title="Agendar via WhatsApp">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M12.031 6.172c-2.315 0-4.191 1.876-4.191 4.191 0 2.315 1.876 4.191 4.191 4.191 2.315 0 4.191-1.876 4.191-4.191 0-2.315-1.876-4.191-4.191-4.191zm7.56 5.828c0 4.072-3.303 7.375-7.375 7.375s-7.375-3.303-7.375-7.375 3.303-7.375 7.375-7.375 7.375 3.303 7.375 7.375z" opacity=".4"/>
                        <path d="M12.031 2.375c-5.412 0-9.813 4.401-9.813 9.813 0 1.733.454 3.359 1.242 4.773l-1.321 4.825 4.954-1.3c1.4.75 2.983 1.177 4.671 1.177 5.412 0 9.813-4.401 9.813-9.813s-4.401-9.813-9.813-9.813zm5.415 13.918c-.244.686-1.229 1.259-1.696 1.341-.467.082-.916.123-2.909-.675-2.541-1.018-4.225-3.568-4.352-3.737-.127-.169-.941-1.254-.941-2.392 0-1.138.591-1.693.803-1.921.212-.228.467-.285.623-.285.155 0 .31.001.446.007.143.006.335-.054.526.406.191.46.654 1.595.711 1.708.057.113.095.244.02.394-.075.15-.113.244-.225.375-.113.131-.237.292-.338.393-.113.113-.232.235-.1.464.131.23.585.955 1.255 1.554.854.762 1.536 1.001 1.761 1.114.225.113.355.096.488-.056.133-.152.569-.661.721-.887.152-.226.304-.188.513-.113s1.334.629 1.562.742c.228.113.38.169.436.264.056.095.056.551-.188 1.237z"/>
                      </svg>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </details>
        </div>
      </div>
      
      <div class="text-center mt-4">
        <a href="/servicos" class="btn btn-primary">Ver detalhes dos serviços</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials section">
    <div class="container">
      <h2 class="text-center">O que dizem as mamães</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p>"A Elis foi um anjo no meu pós-parto. O taping ajudou muito na minha recuperação e o carinho dela me deu muita segurança."</p>
          <div class="author">
            <strong>Mariana S.</strong>
            <span>Suzano, SP</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p>"Poder ouvir o coração do meu pequeno em casa foi emocionante. A Elis é extremamente profissional e delicada."</p>
          <div class="author">
            <strong>Fernanda L.</strong>
            <span>Mogi das Cruzes, SP</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container cta-container">
      <h2>Pronta para um cuidado humanizado?</h2>
      <p>Entre em contato agora e tire suas dúvidas ou agende uma visita domiciliar.</p>
      <a href="https://wa.me/5511986214894" class="btn btn-whatsapp">Falar com Elis no WhatsApp</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 80px 0 40px;
    background: linear-gradient(135deg, var(--rose) 0%, #fff 100%);
    min-height: 70vh;
    display: flex;
    align-items: center;
  }
  
  .hero-container {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }
  
  .badge {
    display: inline-block;
    padding: 5px 14px;
    border: 1px solid var(--primary);
    color: var(--primary);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 25px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
  
  .hero-content h1 {
    font-size: 3rem;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  
  .hero-content h1 span {
    color: var(--primary);
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
  }
  
  .hero-content p {
    font-size: 1.05rem;
    color: var(--text-light);
    margin-bottom: 35px;
    max-width: 480px;
    line-height: 1.7;
  }
  
  .hero-actions {
    display: flex;
    gap: 12px;
  }
  
  .btn-whatsapp {
    background-color: #25d366;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.2);
  }

  .btn-outline {
    border: 1px solid var(--primary);
    color: var(--primary);
    background: transparent;
  }
  
  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }
  
  .hero-image .image-wrapper {
    position: relative;
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    animation: blob 10s infinite alternate;
  }
  
  @keyframes blob {
    0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
    100% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; }
  }
  
  .authority-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  .authority-card {
    text-align: center;
    padding: 40px;
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  
  .authority-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-md);
  }
  
  .authority-card .icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }
  
  .bg-light {
    background-color: var(--gray);
  }
  
  .section-subtitle {
    margin-bottom: 50px;
    color: var(--text-light);
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 40px;
  }
  
  .service-card {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  
  .service-card.highlight {
    border: 2px solid var(--primary);
    transform: scale(1.05);
  }
  
  .service-image img {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }
  
  .service-info {
    padding: 25px;
  }
  
  .service-info h3 {
    margin-bottom: 10px;
    font-size: 1.4rem;
  }
  
  .service-info .price {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    margin: 15px 0;
  }
  
  .btn-text {
    font-weight: 600;
    color: var(--dark-brown);
  }

  /* Home Procedures Styles */
  .home-procedures {
    max-width: 800px;
    margin: 0 auto;
  }

  .accordion {
    border: 1px solid var(--rose);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: var(--white);
  }

  summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 25px;
    cursor: pointer;
    font-weight: 600;
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--dark-brown);
    list-style: none;
    transition: var(--transition);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary:hover {
    background-color: var(--rose);
  }

  summary svg {
    transition: transform 0.3s ease;
    color: var(--primary);
  }

  details[open] summary svg {
    transform: rotate(180deg);
  }

  .accordion-content {
    padding: 0 25px 25px;
    border-top: 1px solid var(--rose);
    background-color: var(--gray);
  }

  .procedures-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    padding-top: 15px;
  }

  .procedure-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--rose);
  }

  .procedure-item:last-child {
    border-bottom: none;
  }

  .procedure-title {
    font-size: 0.95rem;
    color: var(--text-dark);
  }

  .procedure-divider {
    flex-grow: 1;
    border-bottom: 1px dotted var(--primary);
    opacity: 0.2;
  }

  .procedure-price {
    font-weight: 700;
    color: var(--primary);
    white-space: nowrap;
    font-size: 0.95rem;
  }

  .procedure-link {
    color: #25d366;
    display: flex;
    align-items: center;
    transition: var(--transition);
  }

  .procedure-link:hover {
    transform: scale(1.2);
  }
  
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  
  .testimonial-card {
    padding: 40px;
    background: var(--rose);
    border-radius: var(--radius);
    position: relative;
  }
  
  .testimonial-card p {
    font-style: italic;
    margin-bottom: 20px;
    font-size: 1.1rem;
  }
  
  .author strong {
    display: block;
    color: var(--dark-brown);
  }
  
  .cta-container {
    background: var(--dark-brown);
    border-radius: var(--radius);
    padding: 80px 40px;
    text-align: center;
    color: var(--white);
  }
  
  .cta-container h2 {
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: 20px;
  }
  
  .cta-container p {
    margin-bottom: 40px;
    font-size: 1.2rem;
    opacity: 0.9;
  }
  
  .mt-4 { margin-top: 40px; }

  @media (max-width: 992px) {
    .header-inner { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
    .hero { padding: 140px 0 60px; }
    .hero-container { 
      display: flex;
      flex-direction: column;
      text-align: center; 
      gap: 40px; 
    }
    .hero-image {
      order: -1;
      max-width: 280px;
      margin: 0 auto;
    }
    .hero-content h1 { 
      font-size: 2.2rem; 
      margin-bottom: 15px;
      line-height: 1.2;
    }
    .hero-content p { 
      margin: 0 auto 30px; 
      font-size: 1rem; 
      line-height: 1.6;
    }
    .hero-actions { 
      flex-direction: column; 
      gap: 12px;
      max-width: 280px;
      margin: 0 auto;
    }
    .hero-actions .btn { width: 100%; }
    .authority-grid, .services-grid, .testimonials-grid { grid-template-columns: 1fr; gap: 30px; }
    .service-card.highlight { transform: scale(1); }
    .badge { 
      margin-bottom: 15px; 
      font-size: 0.7rem;
      padding: 4px 12px;
    }
  }
</style>
