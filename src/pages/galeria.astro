---
import Layout from '../layouts/Layout.astro';

// Array of images found in public/images/galeria/
// When the client adds photos to that folder, they can be listed here
const galleryImages = [
  // { src: '/images/galeria/foto1.jpg', alt: 'Descrição da foto 1' },
];

const title = "Galeria de Momentos - Elis de Sá";
const description = "Veja os momentos de cuidado e carinho no atendimento humanizado da enfermeira Elis de Sá em Suzano.";
---

<Layout title={title} description={description}>
  <section class="gallery-hero">
    <div class="container fade-in">
      <span class="subtitle">Nossa História</span>
      <h1>Galeria de Momentos</h1>
      <p class="description">
        Registros de cuidado, carinho e a beleza do nascimento e do acompanhamento materno-infantil.
      </p>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      {galleryImages.length > 0 ? (
        <div class="gallery-grid">
          {galleryImages.map((image, index) => (
            <div class="gallery-item" style={`animation-delay: ${index * 0.1}s`}>
              <img src={image.src} alt={image.alt} loading="lazy" />
              <div class="overlay">
                <span>{image.alt}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-gallery text-center fade-in">
          <div class="empty-icon">📸</div>
          <h3>A galeria está sendo preparada</h3>
          <p>Em breve, fotos de momentos especiais serão adicionadas aqui.</p>
          <div class="instructions">
            <p><small>Dica: Adicione suas fotos na pasta <code>public/images/galeria/</code> e atualize a lista no arquivo <code>src/pages/galeria.astro</code>.</small></p>
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .gallery-hero {
    background: linear-gradient(rgba(250, 237, 205, 0.5), rgba(255, 255, 255, 1));
    padding: 100px 0 60px;
    text-align: center;
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    display: block;
    margin-bottom: 15px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 20px;
  }

  .description {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-light);
    font-size: 1.1rem;
  }

  .gallery-section {
    padding: 60px 0 100px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
    animation: fadeIn 1s ease;
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/5;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    cursor: pointer;
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(88, 47, 14, 0.8));
    padding: 20px;
    color: white;
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
  }

  .gallery-item:hover .overlay {
    opacity: 1;
  }

  .empty-gallery {
    padding: 100px 20px;
    background: var(--gray);
    border-radius: var(--radius);
    border: 2px dashed var(--rose);
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 20px;
  }

  .empty-gallery h3 {
    margin-bottom: 10px;
    color: var(--dark-brown);
  }

  .empty-gallery p {
    color: var(--text-light);
  }

  .instructions {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--rose);
    opacity: 0.7;
  }

  code {
    background: var(--rose);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .gallery-hero {
      padding: 80px 0 40px;
    }
  }
</style>
