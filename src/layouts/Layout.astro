---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappButton from '../components/WhatsappButton.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { 
  title, 
  description = "Elis de Sá - Enfermeira Obstétrica e Assistencial em Suzano. Atendimento humanizado, cuidados pós-parto, taping e monitoramento materno-infantil.",
  image = "/og-image.jpg",
  canonicalURL = Astro.url.href
} = Astro.props;

const businessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalBusiness"],
  "@id": "https://elis-de-sa-enfermeira.com.br/#business",
  "name": "Elis de Sá - Enfermeira",
  "image": "https://elis-de-sa-enfermeira.com.br/logo.png",
  "description": "Enfermeira obstétrica e assistencial com atendimento humanizado em Suzano. Especialista Einstein.",
  "url": "https://elis-de-sa-enfermeira.com.br",
  "telephone": "+5511986214894",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Estrada Santa Mônica, 1373",
    "addressLocality": "Suzano",
    "addressRegion": "SP",
    "postalCode": "08610-000",
    "addressCountry": "BR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -23.5186, 
    "longitude": -46.3323
  },
  "medicalSpecialty": "Obstetrics",
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "08:00",
      "closes": "20:00"
    }
  ]
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    
    <title>{title} | Elis de Sá - Enfermeira</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<WhatsappButton />
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
</style>
